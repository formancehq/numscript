{
  "$schema": "https://raw.githubusercontent.com/formancehq/numscript/main/specs.schema.json",
  "featureFlags": [
    "experimental-overdraft-function"
  ],
  "testCases": [
    {
      "it": "should not emit postings",
      "balances": [
        {
          "account": "alice",
          "asset": "EUR",
          "amount": 100
        }
      ],
      "expect.postings": []
    },
    {
      "it": "should send the missing amount to an overdraft account",
      "balances": [
        {
          "account": "alice",
          "asset": "EUR",
          "amount": -100
        }
      ],
      "expect.endBalances": [
        {
          "account": "alice",
          "asset": "EUR",
          "amount": 0
        },
        {
          "account": "world",
          "asset": "EUR",
          "amount": -100
        }
      ],
      "expect.movements": {
        "world": {
          "alice": {
            "EUR": 100
          }
        }
      },
      "expect.postings": [
        {
          "source": "world",
          "destination": "alice",
          "amount": 100,
          "asset": "EUR"
        }
      ]
    }
  ]
}
