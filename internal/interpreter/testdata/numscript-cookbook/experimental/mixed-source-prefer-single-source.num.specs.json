{
  "$schema": "https://raw.githubusercontent.com/formancehq/numscript/main/specs.schema.json",
  "variables": {
    "amt": "10"
  },
  "featureFlags": [
    "experimental-oneof"
  ],
  "testCases": [
    {
      "it": "sends from the first source when there is enough balance",
      "balances": [
        {
          "account": "s1",
          "asset": "USD",
          "amount": 999
        }
      ],
      "expect.postings": [
        {
          "source": "s1",
          "destination": "dest",
          "amount": 10,
          "asset": "USD"
        }
      ]
    },
    {
      "it": "sends from the second one when it has enough balance but the first one doesn't",
      "balances": [
        {
          "account": "s1",
          "asset": "USD",
          "amount": 9
        },
        {
          "account": "s2",
          "asset": "USD",
          "amount": 999
        }
      ],
      "expect.postings": [
        {
          "source": "s2",
          "destination": "dest",
          "amount": 10,
          "asset": "USD"
        }
      ]
    },
    {
      "it": "sends partially from both when none of them has enough balance on its own",
      "balances": [
        {
          "account": "s1",
          "asset": "USD",
          "amount": 6
        },
        {
          "account": "s2",
          "asset": "USD",
          "amount": 9
        }
      ],
      "expect.postings": [
        {
          "source": "s1",
          "destination": "dest",
          "amount": 6,
          "asset": "USD"
        },
        {
          "source": "s2",
          "destination": "dest",
          "amount": 4,
          "asset": "USD"
        }
      ]
    },
    {
      "it": "fails if there aren't enough funds between all sources",
      "balances": [
        {
          "account": "s1",
          "asset": "USD",
          "amount": 5
        },
        {
          "account": "s2",
          "asset": "USD",
          "amount": 4
        }
      ],
      "expect.error.missingFunds": true
    }
  ]
}
