{
  "$schema": "https://raw.githubusercontent.com/formancehq/numscript/main/specs.schema.json",
  "testCases": [
    {
      "it": "is capped to USD100 when balance is higher",
      "balances": [
        {
          "account": "src",
          "asset": "USD",
          "amount": 999
        }
      ],
      "expect.postings": [
        {
          "source": "src",
          "destination": "dest",
          "amount": 100,
          "asset": "USD"
        }
      ]
    },
    {
      "it": "allows sending less than the cap when balance is not enough",
      "balances": [
        {
          "account": "src",
          "asset": "USD",
          "amount": 42
        }
      ],
      "expect.postings": [
        {
          "source": "src",
          "destination": "dest",
          "amount": 42,
          "asset": "USD"
        }
      ]
    }
  ]
}
