{
  "$schema": "https://raw.githubusercontent.com/formancehq/numscript/main/specs.schema.json",
  "featureFlags": [
    "experimental-oneof",
    "experimental-asset-scaling"
  ],
  "balances": [
    {
      "account": "acc2",
      "asset": "EUR/2",
      "amount": 100
    }
  ],
  "testCases": [
    {
      "it": "fallbacks to the second branch when there's not enough",
      "balances": [
        {
          "account": "acc1",
          "asset": "EUR/2",
          "amount": 1
        }
      ],
      "expect.postings": [
        {
          "source": "acc1",
          "destination": "dest",
          "amount": 1,
          "asset": "EUR/2"
        },
        {
          "source": "acc2",
          "destination": "dest",
          "amount": 99,
          "asset": "EUR/2"
        }
      ]
    },
    {
      "it": "succeeds in the first branch",
      "balances": [
        {
          "account": "acc1",
          "asset": "EUR/2",
          "amount": 100
        }
      ],
      "expect.postings": [
        {
          "source": "acc1",
          "destination": "dest",
          "amount": 100,
          "asset": "EUR/2"
        }
      ]
    }
  ]
}
